# Logging: debug | info | warn | error  (default: info)
# Set LOG_LEVEL=debug to see hex dumps of all unknown/unhandled packets
LOG_LEVEL=info

# Login Server
LOGIN_ADDR=0.0.0.0:2000

# Game Server
GAME_ADDR=0.0.0.0:5000
# IP that login server tells clients to connect to (your external/LAN IP)
GAME_PUBLIC_IP=127.0.0.1
GAME_PUBLIC_PORT=5000

# PostgreSQL
DB_DSN=postgres://r2:r2password@localhost:5432/r2online?sslmode=disable

# Redis (session tokens shared between login and game servers)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Session token TTL (seconds)
SESSION_TTL=300

# --- Crypto offset diagnostics (optional) ---
# Mutate 18 bytes in welcome(1103) at payload offset. Disabled when -1.
# Try values: 96, 153, 155
WELCOME_KEY_MUTATE_OFFSET=-1

# Incoming packet decrypt mode:
# - static  : legacy hardcoded sbox (current working mode)
# - welcome : derive RC4 sbox from 18 bytes inside welcome payload
RECV_SBOX_MODE=static

# Used only when RECV_SBOX_MODE=welcome (usually test with 96/153/155).
RECV_SBOX_WELCOME_OFFSET=96

# Log trial opcodes for multiple candidate welcome-key offsets (0/1).
DIAG_WELCOME_SBOXES=0
# Try all 18-byte windows in welcome payload (0/1). Works only if DIAG_WELCOME_SBOXES=1.
DIAG_WELCOME_BRUTE=0

# Extra diagnostic: for each candidate sbox, search RC4 drop-N model
# and log first N that yields opcode 0x0C1C (0/1).
DIAG_DROP_SEARCH=0
# Max N for drop search.
DIAG_DROP_MAX=4096
# Optional expected decrypted sequence byte for drop search:
# -1 disables seq check; typical first client packet uses seq=1.
DIAG_DROP_EXPECT_SEQ=1

# Runtime decrypt model for incoming encrypted packets:
# RECV_RC4_DROP: discard N keystream bytes before decrypt.
# RECV_RC4_STREAM: keep RC4 state across packets (1) instead of reset-per-packet (0).
RECV_RC4_DROP=0
RECV_RC4_STREAM=0
