# Login Server
LOGIN_ADDR=0.0.0.0:11004

# Game Server
GAME_ADDR=0.0.0.0:5000
# IP that login server tells clients to connect to (your external/LAN IP)
GAME_PUBLIC_IP=127.0.0.1
GAME_PUBLIC_PORT=5000

# PostgreSQL
DB_DSN=postgres://r2:r2password@localhost:5432/r2online?sslmode=disable

# Redis (session tokens shared between login and game servers)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Session token TTL (seconds)
SESSION_TTL=300

# LOG_LEVEL=debug

# # WELCOME_KEY_MUTATE_OFFSET=96
# # RECV_SBOX_MODE=static
# # DIAG_WELCOME_SBOXES=1
# # DIAG_WELCOME_BRUTE=0
# # DIAG_DROP_SEARCH=1
# # DIAG_DROP_MAX=8192
# DIAG_WELCOME_SBOXES=1
# DIAG_DROP_SEARCH=1
# DIAG_DROP_EXPECT_SEQ=1
# DIAG_DROP_MAX=8192
# RECV_RC4_DROP=0
# RECV_RC4_STREAM=0

RECV_SBOX_MODE=static
DIAG_WELCOME_SBOXES=0
DIAG_DROP_SEARCH=0
RECV_RC4_DROP=0
RECV_RC4_STREAM=0
# WELCOME_KEY_MUTATE_OFFSET=-1  (или просто не задавать)
LOG_LEVEL=info
